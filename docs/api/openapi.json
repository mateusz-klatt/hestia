{
  "components": {
    "schemas": {
      "ControlCover": {
        "additionalProperties": false,
        "description": "Set a blind/cover position (0..99).",
        "properties": {
          "node": {
            "description": "device node id",
            "maximum": 255,
            "minimum": 0,
            "title": "Node",
            "type": "integer"
          },
          "op": {
            "const": "cover",
            "title": "Op",
            "type": "string"
          },
          "value": {
            "description": "cover position 0..99",
            "maximum": 99,
            "minimum": 0,
            "title": "Value",
            "type": "integer"
          }
        },
        "required": [
          "op",
          "node",
          "value"
        ],
        "title": "ControlCover",
        "type": "object"
      },
      "ControlError": {
        "additionalProperties": false,
        "description": "The 400 (malformed) / 503 (device unavailable) body: ``ok`` false + a human error string.",
        "properties": {
          "error": {
            "title": "Error",
            "type": "string"
          },
          "ok": {
            "title": "Ok",
            "type": "boolean"
          }
        },
        "required": [
          "ok",
          "error"
        ],
        "title": "ControlError",
        "type": "object"
      },
      "ControlLevel": {
        "additionalProperties": false,
        "description": "Set a dimmer level (0..99).",
        "properties": {
          "node": {
            "description": "device node id",
            "maximum": 255,
            "minimum": 0,
            "title": "Node",
            "type": "integer"
          },
          "op": {
            "const": "level",
            "title": "Op",
            "type": "string"
          },
          "value": {
            "description": "dim level 0..99",
            "maximum": 99,
            "minimum": 0,
            "title": "Value",
            "type": "integer"
          }
        },
        "required": [
          "op",
          "node",
          "value"
        ],
        "title": "ControlLevel",
        "type": "object"
      },
      "ControlRequest": {
        "description": "A device control command \u2014 one variant per device op.",
        "discriminator": {
          "mapping": {
            "cover": "#/components/schemas/ControlCover",
            "level": "#/components/schemas/ControlLevel",
            "switch": "#/components/schemas/ControlSwitch",
            "thermostat": "#/components/schemas/ControlThermostat",
            "thermostat_power": "#/components/schemas/ControlThermostatPower"
          },
          "propertyName": "op"
        },
        "oneOf": [
          {
            "$ref": "#/components/schemas/ControlSwitch"
          },
          {
            "$ref": "#/components/schemas/ControlThermostatPower"
          },
          {
            "$ref": "#/components/schemas/ControlLevel"
          },
          {
            "$ref": "#/components/schemas/ControlCover"
          },
          {
            "$ref": "#/components/schemas/ControlThermostat"
          }
        ]
      },
      "ControlSuccess": {
        "additionalProperties": false,
        "description": "The 200 body when a control command reaches the device: ``ok`` true + the ``sent`` wire frame.",
        "properties": {
          "ok": {
            "title": "Ok",
            "type": "boolean"
          },
          "sent": {
            "description": "the device command frame that was sent, hex-encoded",
            "title": "Sent",
            "type": "string"
          }
        },
        "required": [
          "ok",
          "sent"
        ],
        "title": "ControlSuccess",
        "type": "object"
      },
      "ControlSwitch": {
        "additionalProperties": false,
        "description": "Turn a relay/light on or off (optionally a single gang of a multi-gang node).",
        "properties": {
          "endpoint": {
            "description": "multi-gang channel 1 or 2; omit for single-gang",
            "maximum": 2,
            "minimum": 1,
            "title": "Endpoint",
            "type": "integer"
          },
          "node": {
            "description": "device node id",
            "maximum": 255,
            "minimum": 0,
            "title": "Node",
            "type": "integer"
          },
          "on": {
            "title": "On",
            "type": "boolean"
          },
          "op": {
            "const": "switch",
            "title": "Op",
            "type": "string"
          }
        },
        "required": [
          "op",
          "node",
          "on"
        ],
        "title": "ControlSwitch",
        "type": "object"
      },
      "ControlThermostat": {
        "additionalProperties": false,
        "description": "Set a thermostat/TRV target temperature (4..28 \u00b0C).",
        "properties": {
          "celsius": {
            "anyOf": [
              {
                "maximum": 28,
                "minimum": 4,
                "type": "integer"
              },
              {
                "maximum": 28,
                "minimum": 4,
                "type": "number"
              }
            ],
            "description": "target \u00b0C, 4..28",
            "title": "Celsius"
          },
          "node": {
            "description": "device node id",
            "maximum": 255,
            "minimum": 0,
            "title": "Node",
            "type": "integer"
          },
          "op": {
            "const": "thermostat",
            "title": "Op",
            "type": "string"
          }
        },
        "required": [
          "op",
          "node",
          "celsius"
        ],
        "title": "ControlThermostat",
        "type": "object"
      },
      "ControlThermostatPower": {
        "additionalProperties": false,
        "description": "Power a thermostat/TRV on or off.",
        "properties": {
          "node": {
            "description": "device node id",
            "maximum": 255,
            "minimum": 0,
            "title": "Node",
            "type": "integer"
          },
          "on": {
            "title": "On",
            "type": "boolean"
          },
          "op": {
            "const": "thermostat_power",
            "title": "Op",
            "type": "string"
          }
        },
        "required": [
          "op",
          "node",
          "on"
        ],
        "title": "ControlThermostatPower",
        "type": "object"
      },
      "DeviceInfo": {
        "additionalProperties": false,
        "description": "One device, merged from the classifier + the user registry (``proxy._discovery_entry``). The base\n+ live-state fields are ALWAYS present (required), null when unseen \u2014 so `0`/`false` are never lost.\nThe registry labels (``name``/``room``/``endpoint_names``) are OPTIONAL \u2014 absent until set, never null.\n``confidence`` is usually a string but a legacy/hand-edited registry node (a ``type`` without a\n``confidence``) can surface null, so the contract admits it.",
        "properties": {
          "battery": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Battery"
          },
          "confidence": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Confidence"
          },
          "door": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Door"
          },
          "endpoint_names": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Endpoint Names",
            "type": "object"
          },
          "endpoints": {
            "anyOf": [
              {
                "additionalProperties": {
                  "type": "boolean"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Endpoints"
          },
          "energy_kwh": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Energy Kwh"
          },
          "last_seen": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Seen"
          },
          "level": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Level"
          },
          "motion": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Motion"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "power": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Power"
          },
          "power_w": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Power W"
          },
          "room": {
            "title": "Room",
            "type": "string"
          },
          "setpoint": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Setpoint"
          },
          "switch": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Switch"
          },
          "temperature": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Temperature"
          },
          "thermostat_last_cmd": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Thermostat Last Cmd"
          },
          "thermostat_on": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Thermostat On"
          },
          "type": {
            "title": "Type",
            "type": "string"
          },
          "voltage_v": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Voltage V"
          }
        },
        "required": [
          "power",
          "type",
          "confidence",
          "battery",
          "level",
          "switch",
          "door",
          "motion",
          "setpoint",
          "thermostat_on",
          "thermostat_last_cmd",
          "temperature",
          "power_w",
          "energy_kwh",
          "voltage_v",
          "endpoints",
          "last_seen"
        ],
        "title": "DeviceInfo",
        "type": "object"
      },
      "Globals": {
        "additionalProperties": false,
        "description": "Node-less global fields (``proxy.globals_snapshot``). Every key is ALWAYS present (required),\nnull when its poller is off.",
        "properties": {
          "crib_temp": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Crib Temp"
          },
          "outdoor_humidity": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Outdoor Humidity"
          },
          "outdoor_temp": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Outdoor Temp"
          }
        },
        "required": [
          "crib_temp",
          "outdoor_temp",
          "outdoor_humidity"
        ],
        "title": "Globals",
        "type": "object"
      },
      "KlimaState": {
        "additionalProperties": false,
        "description": "The A/C state derived from IR traffic (``state``): power + optional mode/target.",
        "properties": {
          "mode": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Mode"
          },
          "power": {
            "title": "Power",
            "type": "boolean"
          },
          "temp": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Temp"
          }
        },
        "required": [
          "power",
          "mode",
          "temp"
        ],
        "title": "KlimaState",
        "type": "object"
      },
      "LoginRequest": {
        "additionalProperties": false,
        "description": "POST /api/login body. ``bearer: true`` opts a native client into a token in the response (which\nit then sends as ``Authorization: Bearer``); the browser omits it and relies on the httponly cookie.",
        "properties": {
          "bearer": {
            "title": "Bearer",
            "type": "boolean"
          },
          "password": {
            "title": "Password",
            "type": "string"
          },
          "user": {
            "title": "User",
            "type": "string"
          }
        },
        "required": [
          "user",
          "password"
        ],
        "title": "LoginRequest",
        "type": "object"
      },
      "LoginSuccess": {
        "additionalProperties": false,
        "description": "200 from /api/login. ``token`` is present ONLY when the request set ``bearer: true``.",
        "properties": {
          "ok": {
            "title": "Ok",
            "type": "boolean"
          },
          "token": {
            "title": "Token",
            "type": "string"
          },
          "user": {
            "title": "User",
            "type": "string"
          }
        },
        "required": [
          "ok",
          "user"
        ],
        "title": "LoginSuccess",
        "type": "object"
      },
      "OkResult": {
        "additionalProperties": false,
        "description": "A bare ``{ok: true}`` acknowledgement (e.g. /api/logout).",
        "properties": {
          "ok": {
            "title": "Ok",
            "type": "boolean"
          }
        },
        "required": [
          "ok"
        ],
        "title": "OkResult",
        "type": "object"
      },
      "RuleVocab": {
        "additionalProperties": false,
        "description": "The automation-rule grammar the guided form builds from (``automations.rule_vocab``).",
        "properties": {
          "cmp_ops": {
            "items": {
              "type": "string"
            },
            "title": "Cmp Ops",
            "type": "array"
          },
          "condition_types": {
            "items": {
              "type": "string"
            },
            "title": "Condition Types",
            "type": "array"
          },
          "frame_action_ops": {
            "items": {
              "type": "string"
            },
            "title": "Frame Action Ops",
            "type": "array"
          },
          "modes": {
            "items": {
              "type": "string"
            },
            "title": "Modes",
            "type": "array"
          },
          "presence_events": {
            "items": {
              "type": "string"
            },
            "title": "Presence Events",
            "type": "array"
          },
          "state_fields": {
            "additionalProperties": {
              "type": "boolean"
            },
            "title": "State Fields",
            "type": "object"
          },
          "sun_events": {
            "items": {
              "type": "string"
            },
            "title": "Sun Events",
            "type": "array"
          },
          "trigger_types": {
            "items": {
              "type": "string"
            },
            "title": "Trigger Types",
            "type": "array"
          }
        },
        "required": [
          "trigger_types",
          "state_fields",
          "cmp_ops",
          "frame_action_ops",
          "modes",
          "sun_events",
          "presence_events",
          "condition_types"
        ],
        "title": "RuleVocab",
        "type": "object"
      },
      "Summary": {
        "additionalProperties": false,
        "description": "Discovery roster counters (``web._summary``).",
        "properties": {
          "confirmed": {
            "title": "Confirmed",
            "type": "integer"
          },
          "total": {
            "title": "Total",
            "type": "integer"
          },
          "unknown": {
            "title": "Unknown",
            "type": "integer"
          }
        },
        "required": [
          "total",
          "confirmed",
          "unknown"
        ],
        "title": "Summary",
        "type": "object"
      },
      "WhoAmI": {
        "additionalProperties": false,
        "description": "GET /api/whoami \u2014 the caller's identity + RBAC role; both null when auth is off (loopback/dev).",
        "properties": {
          "role": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Role"
          },
          "user": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "User"
          }
        },
        "required": [
          "user",
          "role"
        ],
        "title": "WhoAmI",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Local cloud-free smart-home control API. Generated from hestia/api_contract.py \u2014 do not edit by hand; run `python -m hestia.api_contract`.",
    "title": "hestia API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/control": {
      "post": {
        "description": "Requires the operator role.",
        "operationId": "control",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ControlRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ControlSuccess"
                }
              }
            },
            "description": "command sent to the device"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ControlError"
                }
              }
            },
            "description": "malformed command"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ControlError"
                }
              }
            },
            "description": "device unavailable / command rejected"
          }
        },
        "summary": "Issue a device control command"
      }
    },
    "/api/login": {
      "post": {
        "description": "Public. Sets the httponly session cookie; with `bearer: true` the 200 body also carries a `token` for `Authorization: Bearer` (native clients).",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginSuccess"
                }
              }
            },
            "description": "authenticated"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ControlError"
                }
              }
            },
            "description": "invalid credentials"
          }
        },
        "summary": "Exchange credentials for a session (cookie + optional bearer token)"
      }
    },
    "/api/logout": {
      "post": {
        "description": "Public. Clears the cookie; a bearer client simply discards its token.",
        "operationId": "logout",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResult"
                }
              }
            },
            "description": "logged out"
          }
        },
        "summary": "Clear the session cookie"
      }
    },
    "/api/whoami": {
      "get": {
        "description": "Requires a session (cookie or bearer). user/role are null when auth is off.",
        "operationId": "whoami",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WhoAmI"
                }
              }
            },
            "description": "the current session's identity"
          }
        },
        "summary": "The caller's identity + RBAC role"
      }
    }
  }
}
